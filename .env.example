# ─── Payload CMS ──────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
PAYLOAD_SECRET=your-secret-key-change-this-in-production

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon (neon.tech) — recommended for Vercel + Payload CMS v3
# Supports prepared statements, no PgBouncer conflict, native serverless pooling
# Get your connection string at: https://neon.tech → New Project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# For local dev (SQLite — zero config, no external service needed)
# DATABASE_URL=file:./database.db

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=https://cms.capitalupfitters.com

# ─── Email (for admin notifications) ──────────────────────────────────────────
# Resend (recommended) — get key at resend.com
RESEND_API_KEY=re_your_key_here

# ─── Media Storage ────────────────────────────────────────────────────────────
# Local storage by default (dev). Switch to R2 for production:
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=capital-upfitters-media
# CLOUDFLARE_R2_PUBLIC_URL=https://media.capitalupfitters.com
